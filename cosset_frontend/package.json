    "rm:all": "rm -rf node_modules .next out dist build",
    "re:start": "npm run rm:all && npm install && npm run dev",
    "re:build": "npm run rm:all && npm install && npm run build",
    "dev:ts": "npm run dev & npm run ts:watch",
    "ts": "tsc --noEmit --incremental",
    "ts:watch": "npm run ts -- --watch",
    "start:out": "npx serve@latest out -p 8083"
